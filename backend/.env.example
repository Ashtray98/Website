# DATA-WEAVE Configuration
# Copy this to .env and fill in values

# OpenAI (optional - leave blank for demo mode)
OPENAI_API_KEY=

# Embedding model (demo uses sentence-transformers locally)
USE_OPENAI=false
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gpt-4o-mini

# ChromaDB
CHROMA_PERSIST_DIR=./app/data/chromadb

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Search
TOP_K=5
